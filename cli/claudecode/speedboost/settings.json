{
  "// SPEEDBOOST — Claude Code 5x Speed Config": "Drop this into ~/.claude/settings.json",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "8096"
  },

  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Bash(pwsh *)",
      "Bash(powershell *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(cat *)",
      "Bash(type *)",
      "Bash(Get-Content *)",
      "Bash(Get-ChildItem *)",
      "Bash(Copy-Item *)",
      "Bash(Move-Item *)",
      "Bash(New-Item *)",
      "Bash(Remove-Item *)",
      "Bash(Set-Content *)",
      "Bash(Add-Content *)",
      "Bash(mkdir *)",
      "Bash(echo *)",
      "Bash(Write-Host *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)"
    ],
    "deny": []
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\micha\\.claude\\speedboost\\hooks\\session-start.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\micha\\.claude\\speedboost\\hooks\\pre-read.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],

    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\micha\\.claude\\speedboost\\hooks\\post-compact.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],

    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\micha\\.claude\\speedboost\\hooks\\on-stop.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  },

  "model": "claude-sonnet-4-6",

  "cacheControl": {
    "type": "ephemeral"
  }
}
